{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: build",
      "type": "shell",
      "command": "cmake --build build",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "cmake: watch build (inotifywait)",
      "type": "shell",
      "command": "bash -c \"while inotifywait -e close_write -r CMakeLists.txt src; do cmake --build build; done\"",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
